# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://survivorpool:survivorpool@db:5432/survivorpool

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Google OAuth 2.0
# Create credentials at https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Web application
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Bootstrap only — only needed when setting up a fresh database.
# Run: docker compose exec backend python manage.py sync_season <N>
# After that, the active season is tracked in the database automatically.
# ACTIVE_SEASON=50

# CORS — frontend origin(s), comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# Email — Gmail SMTP
# Generate an App Password at myaccount.google.com/apppasswords (requires 2FA)
# Use the 16-char code (strip spaces) as EMAIL_HOST_PASSWORD
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password

# Public URL of the site — included in notification email links
ADMIN_SITE_URL=https://yourdomain.com
