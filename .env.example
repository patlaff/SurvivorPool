# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://survivorpool:survivorpool@db:5432/survivorpool

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Google OAuth 2.0
# Create credentials at https://console.cloud.google.com/apis/credentials
# Type: OAuth 2.0 Web application
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Survivor season to score (update each season)
ACTIVE_SEASON=50

# CORS — frontend origin(s), comma-separated
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80
